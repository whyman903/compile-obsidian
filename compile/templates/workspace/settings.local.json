{
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__notion",
      "Bash(compile status)",
      "Bash(compile status *)",
      "Bash(compile ingest *)",
      "Bash(compile obsidian *)",
      "Bash(compile health)",
      "Bash(compile health *)",
      "Bash(compile render *)",
      "Bash(compile schema)",
      "Bash(compile schema *)",
      "Edit(.compile/notion-sync-profile.json)",
      "Edit(raw/notion/**)",
      "Bash(compile ingest raw/notion/*)",
      "Bash(compile obsidian refresh)",
      "Bash(compile health)",
      "Bash(uv run compile ingest raw/notion/*)",
      "Bash(uv run compile obsidian refresh)",
      "Bash(uv run compile health)",
      "Grep(~/.local/share/uv/tools/compile-wiki/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-$PWD}/.compile/mywiki-bin/compile status --path . --json-output"
          }
        ]
      }
    ]
  }
}
